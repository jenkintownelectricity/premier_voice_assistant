{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hive215.premier-voice.dev/schemas/external_response_normalized.schema.json",
  "title": "ExternalResponseNormalized",
  "description": "Normalized external API response. Trust level: UNTRUSTED until validated.",
  "type": "object",
  "required": [
    "response_id",
    "api_name",
    "http_status",
    "normalization_verdict",
    "timestamp_utc"
  ],
  "properties": {
    "response_id": {
      "type": "string",
      "format": "uuid"
    },
    "api_name": {
      "type": "string",
      "maxLength": 128,
      "description": "Name of the external API"
    },
    "http_status": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "content_type": {
      "type": ["string", "null"],
      "description": "Response content type header"
    },
    "response_size_bytes": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 10485760,
      "description": "Response body size (max 10MB)"
    },
    "latency_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "normalization_verdict": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected_http_error",
        "rejected_timeout",
        "rejected_malformed",
        "rejected_too_large",
        "rejected_unexpected_type"
      ]
    },
    "normalized_payload": {
      "type": ["object", "null"],
      "description": "Normalized response payload if accepted"
    },
    "error_message": {
      "type": ["string", "null"]
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
