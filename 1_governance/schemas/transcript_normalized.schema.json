{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hive215.premier-voice.dev/schemas/transcript_normalized.schema.json",
  "title": "TranscriptNormalized",
  "description": "Typed, validated transcript record after STT normalization. Trust level: TRUSTED after validation.",
  "type": "object",
  "required": [
    "transcript_id",
    "text",
    "text_cleaned",
    "confidence",
    "confidence_level",
    "source",
    "language",
    "duration_ms",
    "is_final",
    "timestamp_utc",
    "normalization_verdict",
    "word_count"
  ],
  "properties": {
    "transcript_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this transcript record"
    },
    "text": {
      "type": "string",
      "description": "Original raw text from STT"
    },
    "text_cleaned": {
      "type": "string",
      "minLength": 1,
      "maxLength": 10000,
      "description": "Cleaned text with control characters removed and whitespace normalized"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Raw confidence score from STT provider"
    },
    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low", "rejected"],
      "description": "Classified confidence level"
    },
    "source": {
      "type": "string",
      "enum": ["deepgram_nova3", "whisper", "unknown"],
      "description": "STT provider that produced this transcript"
    },
    "language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 10,
      "description": "Language code (e.g., 'en', 'es')"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 300000,
      "description": "Duration of audio segment in milliseconds"
    },
    "is_final": {
      "type": "boolean",
      "description": "Whether this is a final (not interim) transcript"
    },
    "speaker_id": {
      "type": ["string", "null"],
      "description": "Speaker identifier if available"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp of normalization"
    },
    "normalization_verdict": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected_empty",
        "rejected_low_confidence",
        "rejected_malformed",
        "rejected_too_short",
        "rejected_too_long"
      ],
      "description": "Result of normalization validation"
    },
    "word_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of words in cleaned text"
    }
  },
  "additionalProperties": false
}
