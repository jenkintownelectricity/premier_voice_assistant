# ============================================================================
# LIVEKIT CONFIGURATION - WebRTC Voice AI Integration
# ============================================================================
#
# LiveKit enables ultra-low latency voice communication via WebRTC:
# - Transport latency: ~10-20ms (vs 50-150ms for WebSocket)
# - Total voice-to-voice: ~200-300ms (vs 300-500ms for WebSocket)
#
# Choose your deployment:
# 1. LiveKit Cloud (Free until Jan 2026): https://cloud.livekit.io
# 2. Self-hosted on any VPS (Apache 2.0 license)
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# LIVEKIT SERVER CONNECTION
# ─────────────────────────────────────────────────────────────────────────────

# LiveKit server URL
# - Cloud: wss://your-project.livekit.cloud
# - Self-hosted: wss://your-domain.com (or ws:// for local dev)
LIVEKIT_URL=wss://your-project.livekit.cloud

# API credentials (get from LiveKit Cloud console or generate for self-hosted)
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# SELF-HOSTED CONFIGURATION (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# If self-hosting LiveKit server:
# LIVEKIT_HOST=0.0.0.0
# LIVEKIT_PORT=7880
# LIVEKIT_RTC_PORT_START=50000
# LIVEKIT_RTC_PORT_END=60000

# ─────────────────────────────────────────────────────────────────────────────
# VOICE AI PROVIDERS (Same as Lightning Pipeline)
# ─────────────────────────────────────────────────────────────────────────────

# Deepgram STT (~30ms latency)
# Get key: https://console.deepgram.com/
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq LLM (~40ms TTFT)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cartesia TTS (~30ms TTFB)
# Get key: https://play.cartesia.ai/
CARTESIA_API_KEY=sk_car_xxxxxxxxxxxxxxxxxxxxxxxx

# Voice settings (optional)
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
CARTESIA_MODEL=sonic-english
DEEPGRAM_MODEL=nova-2
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────────────────────────────────────
# FALLBACK LLM PROVIDERS (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI (fallback if Groq unavailable)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (fallback)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# QUICK START GUIDE
# ============================================================================
#
# 1. Sign up for LiveKit Cloud: https://cloud.livekit.io
#    - Create a new project
#    - Copy your URL, API Key, and API Secret
#
# 2. Set up voice providers:
#    - Deepgram: https://console.deepgram.com/ ($200 free credits)
#    - Groq: https://console.groq.com/ (14,400 free requests/day)
#    - Cartesia: https://play.cartesia.ai/ ($5 free credits/month)
#
# 3. Start the agent worker:
#    python backend/livekit_worker.py dev
#
# 4. Test the connection:
#    curl http://localhost:8000/livekit/status
#
# ============================================================================
# ARCHITECTURE
# ============================================================================
#
#    User Browser
#         │
#         ▼ WebRTC (UDP) ~10-20ms
#    ┌─────────────────────────────────┐
#    │      LIVEKIT SERVER             │
#    │   (Cloud or Self-Hosted)        │
#    └────────────┬────────────────────┘
#                 │
#    ┌────────────▼────────────────────┐
#    │       LIVEKIT AGENT             │
#    │  ┌──────┐ ┌────┐ ┌────────┐     │
#    │  │Silero│→│Deep│→│ Groq  │→    │
#    │  │ VAD  │ │gram│ │  LLM  │     │
#    │  └──────┘ │STT │ └───┬───┘     │
#    │           └────┘     │          │
#    │                ┌─────▼────┐     │
#    │                │ Cartesia │     │
#    │                │   TTS    │     │
#    │                └──────────┘     │
#    └─────────────────────────────────┘
#
#    Total: ~200-300ms voice-to-voice latency
#
# ============================================================================
