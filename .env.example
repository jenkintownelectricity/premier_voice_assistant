# =============================================================================
# Premier Voice Assistant - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git - it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# MODAL LABS (GPU Services for STT & TTS)
# -----------------------------------------------------------------------------
# Get your tokens at: https://modal.com/settings
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# -----------------------------------------------------------------------------
# LLM PROVIDERS
# -----------------------------------------------------------------------------

# GROQ (Primary - Ultra-fast LPU inference)
# Get your API key at: https://console.groq.com/
# FREE tier available! 40ms TTFT, 800 tok/s
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ANTHROPIC (Fallback - Higher quality reasoning)
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# LLM Configuration
MAX_TOKENS=150
TEMPERATURE=0.7

# LLM Provider Priority (groq, claude)
# Groq is 10-20x faster but Claude may be better for complex reasoning
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_PROVIDER=claude

# -----------------------------------------------------------------------------
# SUPABASE (Database & Authentication)
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # KEEP SECRET - Backend only!

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=8000
DEBUG=true

# Environment (development, staging, production)
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# OPTIONAL: REDIS (for caching)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# ENABLE_RESPONSE_CACHE=true
# CACHE_TTL=3600

# -----------------------------------------------------------------------------
# OPTIONAL: TELEPHONY (if using phone features)
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# VOICE PROCESSING SETTINGS
# -----------------------------------------------------------------------------
# Whisper STT Model (tiny.en, base.en, small.en, medium.en, large-v3)
WHISPER_MODEL=base.en

# TTS Model
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
TTS_LANGUAGE=en

# Default Voice
DEFAULT_VOICE=fabio

# -----------------------------------------------------------------------------
# STREAMING VOICE PIPELINE (Recommended for low latency)
# -----------------------------------------------------------------------------
# Deepgram Nova-3: Streaming STT with ~30ms chunk latency
# Get your API key at: https://console.deepgram.com/
# $200 free credit for new accounts!
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-2
# Use "multi" for auto language detection (code-switching support)
DEEPGRAM_LANGUAGE=en-US

# Cartesia Sonic-3: Streaming TTS with 30ms time-to-first-byte
# Get your API key at: https://play.cartesia.ai/
# Supports 42 languages including 9 Indian languages!
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
CARTESIA_MODEL=sonic-2024-10-01
CARTESIA_LANGUAGE=en

# Voice Cloning (uses same API key)
# Clone voices from 3-10 seconds of audio
# Cross-lingual localization available

# ElevenLabs (Alternative TTS - higher quality, slightly slower)
# Get your API key at: https://elevenlabs.io/
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# VAD and Endpointing Settings
# utterance_end_ms: How long to wait after speech stops (default: 1000ms)
# Higher values = fewer false triggers on "I..." or incomplete words
UTTERANCE_END_MS=1200
ENABLE_BARGE_IN=true

# -----------------------------------------------------------------------------
# PERFORMANCE TARGETS (milliseconds) - Lightning Stack
# -----------------------------------------------------------------------------
# With Groq + Deepgram + Cartesia streaming pipeline:
# - STT: ~30ms (Deepgram Nova streaming chunks)
# - LLM: ~40ms TTFT (Groq Llama 3.3 70B)
# - TTS: ~30ms TTFB (Cartesia Sonic-3)
# - Total perceived: ~150ms (with sentence-level streaming)
TARGET_STT_LATENCY=50
TARGET_LLM_LATENCY=50
TARGET_TTS_LATENCY=50
TARGET_TOTAL_LATENCY=200

# Human conversation threshold is ~500ms
# Anything under 200ms feels instant!

# -----------------------------------------------------------------------------
# LIVEKIT - WebRTC Voice AI (Ultra-Low Latency)
# -----------------------------------------------------------------------------
# LiveKit provides WebRTC-based voice transport with ~10-20ms latency
# vs 50-150ms for WebSocket. Total voice-to-voice: ~200-300ms
#
# Choose your deployment:
# 1. LiveKit Cloud (FREE until Jan 2026): https://cloud.livekit.io
# 2. Self-hosted on any VPS (Apache 2.0 license)

# LiveKit server URL
# - Cloud: wss://your-project.livekit.cloud
# - Self-hosted: wss://your-domain.com
LIVEKIT_URL=wss://your-project.livekit.cloud

# API credentials (from LiveKit Cloud console or self-generated)
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Self-hosted only (optional)
# LIVEKIT_HOST=0.0.0.0
# LIVEKIT_PORT=7880
# LIVEKIT_RTC_PORT_START=50000
# LIVEKIT_RTC_PORT_END=60000

# -----------------------------------------------------------------------------
# CORS CONFIGURATION (for mobile apps)
# -----------------------------------------------------------------------------
# ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.com

# -----------------------------------------------------------------------------
# MONITORING & ANALYTICS
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# RATE LIMITING (requests per minute)
# -----------------------------------------------------------------------------
# RATE_LIMIT_PER_USER=60
# RATE_LIMIT_PER_IP=120

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. Modal: Free tier includes $30/month credit - enough for testing
# 2. Anthropic: Pay-as-you-go pricing (~$3 per million tokens for Sonnet)
# 3. Supabase: Pro tier ($25/month) recommended for production
# 4. Railway: ~$5-20/month depending on usage
#
# Total estimated cost for low-medium traffic: ~$50-100/month
# =============================================================================
